# Maya Chat Environment Variables

# Choose your provider: openai | anthropic | openrouter | 9router | surplus
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o

# OpenAI (direct)
OPENAI_API_KEY=

# Anthropic (direct)
ANTHROPIC_API_KEY=

# OpenRouter (unified 400+ models, https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# 9Router (local proxy - run npx 9router or docker run)
# Routes across 40+ free/paid providers, tracks tokens/costs
NINE_ROUTER_ENABLED=true
NINE_ROUTER_URL=http://localhost:20128

# Surplus Intelligence (spot-market cheap inference)
SURPLUS_INTELLIGENCE_ENABLED=false
SURPLUS_INTELLIGENCE_API_KEY=

# Token tracking
TRACK_COSTS=true
COST_ALERT_THRESHOLD=5.0
